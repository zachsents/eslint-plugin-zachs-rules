{
  "name": "eslint-plugin-object-map",
  "version": "0.1.0",
  "description": "Type-aware ESLint rules for replacing repeated same-name object property maps with spread or pick.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zachsents/eslint-plugin-object-map.git"
  },
  "bugs": {
    "url": "https://github.com/zachsents/eslint-plugin-object-map/issues"
  },
  "homepage": "https://github.com/zachsents/eslint-plugin-object-map#readme",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "typescript-eslint",
    "type-aware",
    "object-spread",
    "pick"
  ],
  "publishConfig": {
    "access": "public"
  },
  "zshy": {
    "exports": {
      ".": "./src/index.ts",
      "./rules/*": "./src/rules/*"
    },
    "cjs": false,
    "conditions": {
      "bun": "src"
    }
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./rules/*": {
      "bun": "./src/rules/*",
      "types": "./dist/rules/*",
      "default": "./dist/rules/*"
    }
  },
  "scripts": {
    "typecheck": "command -v tsgo >/dev/null && tsgo --noEmit || tsc --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix --fix-suggestions",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "bun test",
    "build": "zshy",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run build",
    "prepublishOnly": "bun run check"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20.9"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.62.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.10.1",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^9.39.4",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "3.4.2",
    "prettier-plugin-jsdoc": "^1.8.0",
    "typescript": "^5.9.3",
    "zshy": "^0.7.2"
  }
}
